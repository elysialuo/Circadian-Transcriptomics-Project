!Sample_relation = BioSample: https://www.ncbi.nlm.nih.gov/biosample/SAMN31394047
!Sample_relation = SRA: https://www.ncbi.nlm.nih.gov/sra?term=SRX17979136
!Sample_supplementary_file_1 = ftp://ftp.ncbi.nlm.nih.gov/geo/samples/GSM6664nnn/GSM6664761/suppl/GSM6664761_47.processed_counts.txt.gz
