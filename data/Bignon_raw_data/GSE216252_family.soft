^SAMPLE = GSM6664708
!Sample_title = Renal tubule, control genotype, ZT0, rep 1
!Sample_geo_accession = GSM6664708
!Sample_status = Public on Mar 05 2023
!Sample_submission_date = Oct 20 2022
!Sample_last_update_date = Mar 06 2023
!Sample_type = SRA
!Sample_channel_count = 1
!Sample_source_name_ch1 = Renal tubule
!Sample_organism_ch1 = Mus musculus
!Sample_taxid_ch1 = 10090
!Sample_characteristics_ch1 = tissue: Renal tubule
!Sample_characteristics_ch1 = genotype: Control Genotype
!Sample_characteristics_ch1 = Sex: Male
!Sample_characteristics_ch1 = zeitgeber time: ZT0
!Sample_growth_protocol_ch1 = All experiments were performed on male mice housed under 12-hours light/12-hours dark cycles with ad libitum access to drinking water and a standard laboratory chow diet (KLIBA NAFAG diet 3800). A Bmal1lox/lox/Pax8-rtTA/LC-1 Cre mouse strain was bred on the genetic background of the C57BL/6J mouse from The Jackson Laboratory. Eight weeks old Bmal1lox/lox/Pax8-rtTA/LC1 mice (referred as cKOt mice) and their Bmal1lox/lox littermates (referred as CTRL or control mice) were treated for 2 weeks with Doxycycline (DOX; 2 mg/ml in drinking water along with 20mg/ml sucrose) to induce the Cre recombinase inactivation of the Bmal1 (Arntl) gene.
!Sample_molecule_ch1 = total RNA
!Sample_extract_protocol_ch1 = RNA from renal tubules of 60 mice was directly extracted using RNeasy MiniElute Spin Column (Qiagen).
!Sample_extract_protocol_ch1 = RNA-seq libraries were prepared from 200 ng of total RNA with the Illumina TruSeq Stranded mRNA reagents (Illumina) using a unique dual indexing strategy. Cluster generation was performed with 2 nM of an equimolar pool from the resulting libraries using the Illumina HiSeq 3000/4000 SR Cluster Kit reagents.
!Sample_description = 46
!Sample_description = 46_ZT0_C1_rep1
!Sample_data_processing = Sequencing data were demultiplexed, filtered for failed reads, and written to FASTQ files using the bcl2fastq2 conversion software (version 2.20, Illumina).
!Sample_data_processing = Adapter sequences were removed from reads and low-quality sequences trimmed off with Cutadapt (v. 1.8).
!Sample_data_processing = Reads matching to ribosomal RNA sequences were removed with fastq_screen (v. 0.11.1).
!Sample_data_processing = Remaining reads were further filtered for low complexity with reaper (v. 15-065).
!Sample_data_processing = Reads were aligned against Mus musculus.GRCm38.98 genome using STAR (v. 2.5.3a).
!Sample_data_processing = The number of read counts per gene locus was summarized with htseq-count (v. 0.9.1) using Mus musculus.GRCm38.98 gene annotation.
!Sample_data_processing = Assembly: Mus musculus GRCm38.98
!Sample_data_processing = Supplementary files format and content: *.txt: Read counts for all annotated genes.
!Sample_platform_id = GPL21103
!Sample_contact_name = Leonore,,Wigger
!Sample_contact_email = leonore.wigger@sib.swiss
!Sample_contact_laboratory = Vital-IT
!Sample_contact_institute = Swiss Institute of Bioinformatics
!Sample_contact_address = Amphipôle Building
!Sample_contact_city = Lausanne
!Sample_contact_zip/postal_code = 1015
!Sample_contact_country = Switzerland
!Sample_instrument_model = Illumina HiSeq 4000
!Sample_library_selection = cDNA
!Sample_library_source = transcriptomic
!Sample_library_strategy = RNA-Seq
!Sample_relation = BioSample: https://www.ncbi.nlm.nih.gov/biosample/SAMN31394100
!Sample_relation = SRA: https://www.ncbi.nlm.nih.gov/sra?term=SRX17979083
!Sample_supplementary_file_1 = ftp://ftp.ncbi.nlm.nih.gov/geo/samples/GSM6664nnn/GSM6664708/suppl/GSM6664708_46.processed_counts.txt.gz
!Sample_series_id = GSE216252
